@model ServiceHub.Web.Controllers.ClienteRequest

@{
    ViewData["Title"] = "Editar Cliente";
}

<div class="container mt-4">
    <div class="card shadow-sm border-warning">
        <div class="card-header bg-warning text-dark d-flex justify-content-between align-items-center">
            <h4 class="mb-0"><i class="bi bi-pencil-square"></i> Editar Cliente</h4>
            <span class="badge bg-dark">ID: @ViewContext.RouteData.Values["id"]</span>
        </div>
        <div class="card-body">
            <form asp-action="Edit" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                @* Campo oculto para o ID *@
                <input type="hidden" name="id" value="@ViewContext.RouteData.Values["id"]" />

                <div class="mb-3">
                    <label asp-for="Nome" class="form-label fw-bold">Nome Completo</label>
                    <input asp-for="Nome" class="form-control" />
                    <span asp-validation-for="Nome" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label fw-bold">E-mail</label>
                    <input asp-for="Email" type="email" class="form-control" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                    <button type="submit" class="btn btn-warning fw-bold">
                        <i class="bi bi-save"></i> Salvar Alterações
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>